# securePDF web — public client config (Vite). Copy to .env.local (gitignored).
# These values ship to the browser; Firebase web config is public by design.
#
# Auth is DISABLED unless ALL four VITE_FIREBASE_* below are set. When enabled,
# importing an Office file (docx/xlsx/pptx) requires Google sign-in and consumes
# a daily credit via authAPI; otherwise Office falls back to the unauthenticated
# path during rollout.

VITE_AUTHAPI_URL=https://auth.api.takumi-tokunaga.com

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
# Optional
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=

# Optional: AdSense manual display ad units for the pre-input empty state.
# Use Auto ads page exclusions or keep Auto ads disabled for this app route so
# AdSense does not place ads near the toolbar or file-open controls.
VITE_ADSENSE_CLIENT=
VITE_ADSENSE_EMPTY_TOP_SLOT=
VITE_ADSENSE_EMPTY_BOTTOM_SLOT=
# Set true only when you want local non-production placeholder boxes.
VITE_ADSENSE_PLACEHOLDER=false
