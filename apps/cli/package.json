{
  "name": "securepdf",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "securepdf": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "esbuild src/cli.ts --bundle --platform=node --format=esm --outfile=dist/cli.js --banner:js=\"#!/usr/bin/env node\"",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@securepdf/codecs": "workspace:*",
    "@securepdf/core": "workspace:*",
    "@securepdf/schema": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.0"
  }
}
